{
  "name": "birthday-notification-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:api": "tsx watch src/app/api/server.ts",
    "dev:planner": "tsx watch src/app/planner/index.ts",
    "dev:worker": "tsx watch src/app/worker/index.ts",
    "db:migrate": "node-pg-migrate -m src/infrastructure/db/migrations -d ${DATABASE_URL} up",
    "db:migrate:down": "node-pg-migrate -m src/infrastructure/db/migrations -d ${DATABASE_URL} down"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "node-pg-migrate": "^7.9.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}

NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/birthday_service
AWS_REGION=ap-southeast-2
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_BIRTHDAY_QUEUE_URL=http://localhost:4566/000000000000/birthday-delivery-queue
SQS_BIRTHDAY_DLQ_NAME=birthday-delivery-dlq
SQS_MAX_RECEIVE_COUNT=5
SQS_VISIBILITY_TIMEOUT_SECONDS=30
SQS_MESSAGE_RETENTION_SECONDS=1209600
PLANNER_LOOKBACK_HOURS=48
PLANNER_BATCH_SIZE=500
PLANNER_USER_PAGE_SIZE=1000
PLANNER_POLL_INTERVAL_SECONDS=60
OUTBOUND_BASE_URL=https://example.requestbin.test
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_SQS_WAIT_TIME_SECONDS=10
WORKER_SQS_MAX_MESSAGES=10
